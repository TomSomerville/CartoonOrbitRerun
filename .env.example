FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=True

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=cartoon_orbit
DB_PORT=3306

# cToon image storage
# Absolute path to the base upload directory.
# Images are saved as {CTOON_UPLOAD_DIR}/{series}/{set}/{filename}
# Leave empty to use the default: app/static/ctoons/
CTOON_UPLOAD_DIR=
